{
  "name": "pixelarena-backend",
  "version": "1.0.0",
  "description": "PixelArena - World's largest 1,000,000 pixel USDT marketplace - Production API",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node src/server.js",
    "dev": "nodemon src/server.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop pixelarena-api",
    "test": "jest --runInBand --detectOpenHandles",
    "lint": "eslint src --ext .js",
    "seed": "node src/scripts/seedPixels.js",
    "backup": "node src/scripts/backup.js",
    "migrate": "node src/scripts/migrate.js"
  },
  "author": "PixelArena Team",
  "license": "PROPRIETARY",
  "dependencies": {
    "express": "^4.19.2",
    "mongoose": "^8.4.0",
    "redis": "^4.6.13",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "xss-clean": "^0.1.4",
    "hpp": "^0.2.3",
    "express-validator": "^7.0.1",
    "cookie-parser": "^1.4.6",
    "csurf": "^1.11.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.13.0",
    "socket.io": "^4.7.5",
    "ethers": "^6.12.1",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^2.2.0",
    "sharp": "^0.33.4",
    "nodemailer": "^6.9.13",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.1",
    "express-slow-down": "^2.0.1",
    "validator": "^13.11.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "node-cron": "^3.0.3",
    "archiver": "^7.0.1",
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "eslint": "^8.57.0"
  }
}
